<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <AssemblyName>Braid</AssemblyName>
        <RootNamespace>Braid</RootNamespace>
        <PackageId>braid</PackageId>
        <Title>braid</Title>
        <Description>Deterministic concurrency testing for .NET using explicit async probe points.</Description>
        <Authors>Squirix</Authors>
        <RepositoryUrl>https://github.com/squirix/braid</RepositoryUrl>
        <PackageProjectUrl>https://github.com/squirix/braid</PackageProjectUrl>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <IsPackable>true</IsPackable>
    </PropertyGroup>
</Project>
